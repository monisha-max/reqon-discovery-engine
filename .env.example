# LLM (at least one recommended for smart planning and classification)
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_PROVIDER=openai

# Neo4j (required for intelligence scoring and history)
# Docker compose sets these automatically. Only needed for manual setup.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=reqonpassword
NEO4J_DATABASE=neo4j

# Redis (optional, fails gracefully)
REDIS_URL=redis://localhost:6379/0

# Tenant
REQON_DEFAULT_TENANT=default

# Crawl defaults
MAX_PAGES=100
MAX_DEPTH=5
CRAWL_TIMEOUT=300

# Output
OUTPUT_DIR=output

# Performance testing defaults
PERF_TEST_LOAD_USERS=10
PERF_TEST_LOAD_DURATION=30
PERF_TEST_STRESS_MAX_USERS=50
PERF_TEST_STRESS_DURATION=60
PERF_TEST_SOAK_USERS=10
PERF_TEST_SOAK_DURATION=120
