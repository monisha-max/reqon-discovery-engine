# ─────────────────────────────────────────────
# LLM — at least ONE is required
# Used by: planner, page classifier (fallback),
#          perf script generator, results analyzer
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Which LLM provider to use ("openai" or "anthropic")
LLM_PROVIDER=openai

# ─────────────────────────────────────────────
# Redis — OPTIONAL (fails gracefully if missing)
# Used by: orchestrator state persistence, message bus
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# PostgreSQL — OPTIONAL (not used in current code paths)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user@localhost:5432/reqon

# ─────────────────────────────────────────────
# Crawl defaults (override CLI flags if not passed)
# ─────────────────────────────────────────────
MAX_PAGES=100
MAX_DEPTH=5
CRAWL_TIMEOUT=300

# ─────────────────────────────────────────────
# Output directory
# ─────────────────────────────────────────────
OUTPUT_DIR=output

# ─────────────────────────────────────────────
# Performance testing defaults (Layer 3)
# ─────────────────────────────────────────────
PERF_TEST_LOAD_USERS=10
PERF_TEST_LOAD_DURATION=30
PERF_TEST_STRESS_MAX_USERS=50
PERF_TEST_STRESS_DURATION=60
PERF_TEST_SOAK_USERS=10
PERF_TEST_SOAK_DURATION=120
